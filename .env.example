EXECUTION_MODE=SIMULATED
ENABLE_PAPER_MODE=true

# Trading runtime
ENV=DEMO
HOST=0.0.0.0
PORT=8000
DEFAULT_SYMBOL=BTC/USD
TRADING_PAIR=XBTUSD
TIMEFRAME=1m
WORKER_INTERVAL_SECONDS=30
AUTO_START_WORKER=true
DATA_MODE=SYNTHETIC
MARKET_LIMIT=200
HISTORICAL_DAYS=30

# Portfolio & Risk
STARTING_BALANCE=10000
MAX_CAPITAL_PER_TRADE=0.10
MAX_OPEN_POSITIONS=2
STOP_LOSS_PCT=0.02
TAKE_PROFIT_PCT=0.05
MAX_DRAWDOWN_PCT=0.05
MAX_DAILY_LOSS_PCT=0.05
MAX_SYMBOL_EXPOSURE_PCT=0.20
ATR_RISK_MULTIPLIER=1.5
FEE_BPS=20
SLIPPAGE_BPS=10
RISK_FRACTION=0.02
MAX_CONSECUTIVE_LOSSES=5
MIN_CONFIDENCE=0.60
FORCE_KRAKEN_FAILURE=false
CHAIN_ID=11155111
AGENT_NAME=AURORA-AI
AGENT_URI=https://aurora-ai-agent.dev/metadata.json
PRISM_API_KEY=
PRISM_BASE_URL=https://api.prismapi.ai
